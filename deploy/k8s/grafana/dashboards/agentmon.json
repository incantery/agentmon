{
  "uid": "agentmon",
  "title": "agentmon",
  "schemaVersion": 39,
  "refresh": "10s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Events/min by type",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (type) (count_over_time({job=\"agentmon\"}[1m]))"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Needs attention (idle events, 5m)",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({job=\"agentmon\", type=\"session_idle\"}[5m]))"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Turns completed (1h)",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(count_over_time({job=\"agentmon\", type=\"turn_completed\"}[1h]))"
        }
      ]
    },
    {
      "id": 4,
      "type": "logs",
      "title": "Attention stream (idle / ended)",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": { "sortOrder": "Descending", "wrapLogMessage": true },
      "targets": [
        {
          "refId": "A",
          "expr": "{job=\"agentmon\", type=~\"session_idle|session_ended\"}"
        }
      ]
    },
    {
      "id": 5,
      "type": "logs",
      "title": "Live event stream",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "loki", "uid": "loki" },
      "options": { "sortOrder": "Descending" },
      "targets": [
        { "refId": "A", "expr": "{job=\"agentmon\"}" }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Cost (24h, USD)",
      "gridPos": { "h": 7, "w": 6, "x": 0, "y": 18 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 2 } },
      "targets": [
        {
          "refId": "A",
          "instant": true,
          "expr": "sum(sum_over_time({job=\"agentmon\", type=\"assistant_message\"} | json | unwrap payload_cost_usd | __error__=\"\" [24h]))"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Cost/hour by model (USD)",
      "gridPos": { "h": 7, "w": 18, "x": 6, "y": 18 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": { "defaults": { "unit": "currencyUSD" } },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (payload_model) (sum_over_time({job=\"agentmon\", type=\"assistant_message\"} | json | unwrap payload_cost_usd | __error__=\"\" [$__auto]))"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Tokens/hour (output vs cache-read)",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 25 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "legendFormat": "output",
          "expr": "sum(sum_over_time({job=\"agentmon\", type=\"assistant_message\"} | json | unwrap payload_output_tokens | __error__=\"\" [$__auto]))"
        },
        {
          "refId": "B",
          "legendFormat": "cache read",
          "expr": "sum(sum_over_time({job=\"agentmon\", type=\"assistant_message\"} | json | unwrap payload_cache_read_tokens | __error__=\"\" [$__auto]))"
        }
      ]
    },
    {
      "id": 9,
      "type": "table",
      "title": "Top sessions by cost (24h)",
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 25 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": { "defaults": { "unit": "currencyUSD", "decimals": 3 } },
      "targets": [
        {
          "refId": "A",
          "instant": true,
          "expr": "topk(10, sum by (session_id) (sum_over_time({job=\"agentmon\", type=\"assistant_message\"} | json | unwrap payload_cost_usd | __error__=\"\" [24h])))"
        }
      ]
    },
    {
      "id": 10,
      "type": "stat",
      "title": "Unpriced messages (24h)",
      "description": "Assistant messages with real token usage but no cost_usd: the model is missing from internal/pricing. Omitted cost = unpriced, NOT free — nonzero here means cost totals are undercounting. Zero-usage continuation lines (dedupe lines of multi-block responses) are excluded.",
      "gridPos": { "h": 7, "w": 6, "x": 0, "y": 32 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "instant": true,
          "expr": "sum(count_over_time({job=\"agentmon\", type=\"assistant_message\"} | json | payload_cost_usd=\"\" | payload_output_tokens!=\"0\" or payload_input_tokens!=\"0\" [24h])) or vector(0)"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Cost/hour by agent type (USD)",
      "description": "Blank agent_type = the interactive session's own messages; named types are subagent fleets (general-purpose, workflow-subagent, ...).",
      "gridPos": { "h": 7, "w": 18, "x": 6, "y": 32 },
      "datasource": { "type": "loki", "uid": "loki" },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD"
        }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (agent_type) (sum_over_time({job=\"agentmon\", type=\"assistant_message\"} | json | unwrap payload_cost_usd | __error__=\"\" [$__auto]))"
        }
      ]
    },
    {
      "id": 12,
      "type": "table",
      "title": "Unpriced messages by model (24h)",
      "description": "Models that need a row in internal/pricing (zero-usage continuation lines excluded). Empty table = every model priced.",
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 39 },
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "refId": "A",
          "instant": true,
          "expr": "topk(10, sum by (payload_model) (count_over_time({job=\"agentmon\", type=\"assistant_message\"} | json | payload_cost_usd=\"\" | payload_output_tokens!=\"0\" or payload_input_tokens!=\"0\" [24h])))"
        }
      ]
    }
  ]
}
